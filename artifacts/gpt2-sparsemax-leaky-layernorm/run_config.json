{
  "model_name": "gpt2",
  "dataset_name": "openwebtext",
  "block_size": 1024,
  "seed": 1337,
  "train_batch_size_per_device": 8,
  "eval_batch_size_per_device": 8,
  "gradient_accumulation_steps": 4,
  "learning_rate": 0.00002,
  "weight_decay": 0.1,
  "max_grad_norm": 1.0,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_epsilon": 1e-8,
  "warmup_steps": 2000,
  "max_steps": 600000,
  "lr_scheduler_type": "cosine",
  "eval_steps": 20000,
  "save_steps": 20000,
  "logging_steps": 100,
  "save_total_limit": 5,
  "bf16": true,
  "fp16": false,
  "torch_compile": true,
  "gradient_checkpointing": false,
  "dataloader_num_workers": 4,
  "report_to": "none",
  "early_stop_eval_loss": 3.2,
  "preprocessing_num_proc": 8,
  "catastrophic_train_loss_threshold": null,
  "catastrophic_eval_loss_threshold": null,
  "stop_on_inf_grad_norm": true,
  "catastrophic_guard_min_step": 5000,
  "catastrophic_train_increase_delta": 2.0,
  "catastrophic_eval_increase_delta": 2.0,
  "catastrophic_increase_patience": 2,
  "norm_variant": "layernorm",
  "attn_variant": "sparsemax",
  "activation_variant": "leaky_relu"
}
