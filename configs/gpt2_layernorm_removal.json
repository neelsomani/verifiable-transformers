{
  "seed": 1337,
  "train_batch_size_per_device": 2,
  "eval_batch_size_per_device": 2,
  "gradient_accumulation_steps": 16,
  "learning_rate": 0.00001,
  "weight_decay": 0.0,
  "max_grad_norm": 1.0,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_epsilon": 1e-8,
  "warmup_steps": 200,
  "max_steps": 5000,
  "lr_scheduler_type": "cosine",
  "eval_steps": 250,
  "save_steps": 500,
  "logging_steps": 25,
  "save_total_limit": 3,
  "bf16": true,
  "fp16": false,
  "gradient_checkpointing": false,
  "dataloader_num_workers": 4,
  "calibration_steps": 500,
  "transition_steps": 500,
  "gap_steps": 100,
  "ema_momentum": 0.9,
  "fold_tolerance": 0.02,
  "bandnorm_loss_delta_gate": 0.196,
  "decision_rule": "Choose norm-free only if its final eval-loss increase over the matched standard-LN run is below 0.196; otherwise retain BandNorm."
}
